# 1. 파이썬 가상환경 (용량이 크고 각자 생성해야 함)
.venv/
venv/
ENV/

# 2. 파이썬 실행 시 생성되는 캐시 파일
__pycache__/
*.py[cod]
*$py.class

# 3. 환경 변수 파일 (DB 접속 정보 등 민감 정보)
.env

# 4. 사용자 업로드 파일 (깃허브 용량 방지 및 개인정보 보호)
# static/plants 폴더 안의 사진들은 올리지 않음
static/plants/*
!static/plants/.gitkeep

# 5. OS 관련 설정 파일
.DS_Store
Thumbs.db

# 6. IDE(에디터) 설정
.vscode/
.idea/